POSTGRES_DB=hallenverwaltung_test
POSTGRES_USER=hallenverwaltung
POSTGRES_PASSWORD=replace-with-test-database-password

APP_ENV=test
PUBLIC_BASE_URL=https://hallenverwaltung.hofreither.at
AUTH_URL=https://hallenverwaltung.hofreither.at
AUTH_SECRET=replace-with-a-long-random-test-secret
AUTH_TRUST_HOST=true
PUBLIC_AREA_ENABLED=false
TEST_DATA_TOOLS_ENABLED=true
TEST_BOOTSTRAP_TOKEN=replace-with-a-long-random-test-bootstrap-token

SERVER_NAME=hallenverwaltung.hofreither.at
TLS_CERT_DIR=./deploy/certs-test

WORKER_INTERVAL_SECONDS=300

# Test environments may keep delivery disabled until a test mailbox is ready.
MAIL_DELIVERY_MODE=disabled
SMTP_HOST=smtp.test.example.org
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=smtp-test-user
SMTP_PASSWORD=replace-with-test-smtp-password
SMTP_FROM_EMAIL=hallenverwaltung-test@example.org
SMTP_FROM_NAME=Hallenverwaltung St. Valentin Test
