POSTGRES_DB=hallenverwaltung
POSTGRES_USER=hallenverwaltung
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

# For local npm commands use localhost; Docker Compose overrides this for containers.
DATABASE_URL="postgresql://hallenverwaltung:change-me@localhost:5432/hallenverwaltung?schema=public"

# Auth.js requires a long random secret in deployed environments.
AUTH_SECRET="replace-with-a-long-random-secret"
# Required when the application is reached through the configured local or Docker host.
AUTH_TRUST_HOST="true"

# Optional: creates/updates an initial Super-Admin account during `npm run db:seed`.
SEED_ADMIN_EMAIL="admin@example.test"
SEED_ADMIN_PASSWORD="replace-before-seeding"
