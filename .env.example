POSTGRES_DB=hallenverwaltung
POSTGRES_USER=hallenverwaltung
POSTGRES_PASSWORD=change-me
POSTGRES_PORT=5432

APP_ENV=local
PUBLIC_BASE_URL="http://localhost:3000"

# For local npm commands use localhost; Docker Compose overrides this for containers.
DATABASE_URL="postgresql://hallenverwaltung:change-me@localhost:5432/hallenverwaltung?schema=public"

# Auth.js requires a long random secret in deployed environments.
AUTH_SECRET="replace-with-a-long-random-secret"
# Required when the application is reached through the configured local or Docker host.
AUTH_TRUST_HOST="true"
# Optional: set to "false" to disable /public by default until an admin setting is stored.
PUBLIC_AREA_ENABLED="true"

# Optional: creates/updates an initial Super-Admin account during `npm run db:seed`.
SEED_ADMIN_EMAIL="admin@example.test"
SEED_ADMIN_PASSWORD="replace-before-seeding"

# SMTP mail delivery for notification emails
MAIL_DELIVERY_MODE="disabled"
SMTP_HOST="smtp.example.test"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="smtp-user"
SMTP_PASSWORD="replace-with-smtp-password"
SMTP_FROM_EMAIL="hallenverwaltung@example.test"
SMTP_FROM_NAME="Hallenverwaltung St. Valentin"
